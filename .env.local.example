# Gemini API (server-side only — never expose to the client)
GEMINI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role key for trusted server-side reads/writes
# (bypasses Row Level Security). Keep this server-side only.
SUPABASE_SERVICE_ROLE_KEY=
